generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  /// マスターがユーザー一覧で確認するための平文（本人変更・マスター設定時に更新）
  passwordPlainForMaster String?   @db.Text
  passwordUpdatedAt      DateTime?

  role     Role   @default(MEMBER)

  // 協力隊属性
  missionType MissionType?
  department  String?
  termStart   DateTime?
  termEnd     DateTime?

  // カスタマイズ
  avatarColor   String  @default("#3B82F6")
  avatarLetter  String? // アイコンに表示する1文字（未設定時は名前の頭文字）
  darkMode      Boolean @default(false)
  displayOrder  Int     @default(0) // 表示順（メンバー以外が設定可能）
  wishesEnabled Boolean @default(false) // やりたいこと100（プロフィールでON、Wishが1件以上あるユーザーは移行でON）
  notepadEnabled Boolean @default(true) // メモ帳機能の表示（デフォルトON）

  // Phase 1 Relations
  schedules     Schedule[]
  weeklyReports WeeklyReport[]

  // Phase 2 Relations
  missions               Mission[]
  projects               Project[]
  projectMemberships     ProjectMember[]
  projectTasks           ProjectTask[]           @relation("TaskAssignee")
  events                 Event[]                 @relation("EventCreator")
  eventsUpdated          Event[]                 @relation("EventUpdater")
  eventParticipations    EventParticipation[]
  snsPosts               SNSPost[]
  monthlyReports         MonthlyReport[]         @relation("MonthlyReportCreator")
  monthlyReportRevisions MonthlyReportRevision[] @relation("MonthlyReportRevisionChanger")
  supportRecords         SupportRecord[]
  contacts               Contact[]
  contactHistories       ContactHistory[]

  // Phase 3 Relations
  scheduleSuggestions ScheduleSuggestion[]

  // Phase 4 Relations
  requestsSent         Request[]             @relation("Requester")
  requestsReceived     Request[]             @relation("Requestee")
  inspections          Inspection[]
  wishes               Wish[]
  wishCheckins         WishCheckin[]
  personalModeEnabled  Boolean               @default(false)
  personalProjects     PersonalProject[]
  personalSchedules    PersonalSchedule[]
  notifications        Notification[]
  scheduleParticipants ScheduleParticipant[]

  // ダッシュボード設定（JSON）
  dashboardConfigJson Json?

  // SNSリンク（JSON配列: [{ platform: "instagram", url: "..." }, ...]）
  snsLinks Json?

  // 協力隊催促関連
  nudgeDocumentsUpdated NudgeDocument[] @relation("NudgeUpdater")
  nudgeRevisions        NudgeRevision[] @relation("NudgeRevisionUpdater")

  // テンプレート設定関連
  documentTemplatesUpdated DocumentTemplate[] @relation("TemplateUpdater")

  consultationsAsMember Consultation[] @relation("ConsultationMember")
  consultationsTargeted Consultation[] @relation("ConsultationTargetUser")
  consultationsResolved Consultation[] @relation("ConsultationResolvedBy")
  consultationsAssigned Consultation[] @relation("ConsultationAssignedUsers")
  consultationComments ConsultationComment[] @relation("ConsultationCommentAuthor")

  activityExpenseBudget     ActivityExpenseBudget?  @relation("ActivityExpenseBudgetMember")
  activityExpenseEntries    ActivityExpenseEntry[]  @relation("ActivityExpenseEntryMember")
  activityExpenseBudgetsUpdated ActivityExpenseBudget[] @relation("ActivityExpenseBudgetStaffUpdater")
  activityExpenseEntriesCreated ActivityExpenseEntry[]  @relation("ActivityExpenseEntryCreator")
  activityExpenseEntriesUpdated ActivityExpenseEntry[]  @relation("ActivityExpenseEntryUpdater")
  activityExpenseExamplesCreated ActivityExpenseApprovedExample[] @relation("ActivityExpenseExampleCreator")

  announcementsCreated Announcement[]       @relation("AnnouncementAuthor")
  announcementReads    AnnouncementRead[]

  // 有給・代休管理
  paidLeaveAllocations        PaidLeaveAllocation[]  @relation("PaidLeaveAllocationMember")
  paidLeaveAllocationsUpdated PaidLeaveAllocation[]  @relation("PaidLeaveAllocationUpdater")
  paidLeaveEntries            PaidLeaveEntry[]       @relation("PaidLeaveEntryMember")
  paidLeaveEntriesCreated     PaidLeaveEntry[]       @relation("PaidLeaveEntryCreator")
  unpaidLeaveEntries          UnpaidLeaveEntry[]     @relation("UnpaidLeaveEntryMember")
  unpaidLeaveEntriesCreated   UnpaidLeaveEntry[]     @relation("UnpaidLeaveEntryCreator")
  compensatoryLeaves          CompensatoryLeave[]    @relation("CompensatoryLeaveMember")
  compensatoryLeavesConfirmed CompensatoryLeave[]    @relation("CompensatoryLeaveConfirmer")
  compensatoryLeaveUsagesCreated CompensatoryLeaveUsage[] @relation("CompensatoryLeaveUsageCreator")
  timeAdjustments             TimeAdjustment[]       @relation("TimeAdjustmentMember")
  timeAdjustmentsConfirmed    TimeAdjustment[]       @relation("TimeAdjustmentConfirmer")

  mandatedTeamEventsCreated     MandatedTeamEvent[]            @relation("MandatedTeamEventCreator")
  mandatedTeamEventAttendances  MandatedTeamEventAttendance[]
  mandatedAttendanceAuditAsMember MandatedAttendanceAuditLog[] @relation("MandatedAttendanceMember")
  mandatedAttendanceAuditAsStaff  MandatedAttendanceAuditLog[] @relation("MandatedAttendanceChangedBy")

  governmentAttendances GovernmentAttendance[]
  notepads              Notepad[]
  snsAccounts           SNSAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  MASTER
  MEMBER
  SUPPORT
  GOVERNMENT
}

enum MissionType {
  FREE
  MISSION
}

// ========================================
// スケジュール（Phase 2拡張）
// ========================================

model Schedule {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date // 後方互換性のため残す（startDateと同じ値）
  startDate DateTime @db.Date // 開始日
  endDate   DateTime @db.Date // 終了日（デフォルトはstartDateと同じ）
  startTime String
  endTime   String

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationText String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  title                String?  @db.VarChar(200) // タイトル（短い説明）
  activityDescription String   @db.Text // 活動内容（詳細）
  participants        String[] // User IDの配列（後方互換性のため残す）
  freeNote            String?  @db.Text
  customColor         String?  @db.VarChar(20) // スケジュール個別の色（HEX形式、未設定時はプロジェクト色→ユーザー色）

  /// 個人主催イベントへの応援出勤などで紐づけ
  supportEventId String?
  supportEvent   Event?  @relation("ScheduleSupportEvent", fields: [supportEventId], references: [id], onDelete: SetNull)

  isTemplate      Boolean @default(false)
  recurrenceRule  Json? // { type: 'daily|weekly|monthly', interval: 1, endDate: Date }
  isPending       Boolean @default(false)
  isAutoExtracted Boolean @default(false) // 月次報告自動抽出フラグ

  // 代休・時間調整
  compensatoryLeaveRequired Boolean               @default(false) // 代休が必要か
  compensatoryLeaveType     CompensatoryLeaveType? // FULL_DAY=代休 / TIME_ADJUST=時間調整

  // 休日出勤・休日区分
  isHolidayWork Boolean  @default(false) // 休日出勤フラグ
  isDayOff      Boolean  @default(false) // 休日（有給・無休・代休など）フラグ
  dayOffType    DayOffType? // 休日の種別

  createdBy CreatedBy @default(MANUAL)

  scheduleProgress     ScheduleProgress[]
  suggestions          ScheduleSuggestion[]
  scheduleParticipants ScheduleParticipant[]
  compensatoryLeaves   CompensatoryLeave[]   @relation("CompensatoryLeaveSchedule")
  timeAdjustmentsAsSource TimeAdjustment[]   @relation("TimeAdjustmentSourceSchedule")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([projectId])
  @@index([taskId])
  @@index([locationId])
  @@index([supportEventId])
}

enum CreatedBy {
  MANUAL
  TEMPLATE
  RECURRENCE
}

model Location {
  id       String  @id @default(uuid())
  name     String
  order    Int     @default(0)
  isActive Boolean @default(true)

  schedules Schedule[]
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyReport {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  week   String

  thisWeekActivities Json
  nextWeekPlan       String? @db.Text
  note               String? @db.Text

  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, week])
}

// ========================================
// ミッション管理（旧：起業準備進捗管理）
// ========================================

model Mission {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  missionName       String
  missionType       MissionTypeEnum @default(PRIMARY)
  targetPercentage  Int             @default(100)
  startDate         DateTime?       @db.Date
  endDate           DateTime?       @db.Date
  achievementBorder String?         @db.Text

  approvalStatus  ApprovalStatus @default(DRAFT)
  approvalComment String?        @db.Text
  approvedBy      String?
  approvedAt      DateTime?

  midGoals MidGoal[]
  projects Project[]
  tasks    Task[] // タスク（小目標）
  activityExpenseApprovedExamples ActivityExpenseApprovedExample[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model MidGoal {
  id        String  @id @default(uuid())
  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  name         String
  weight       Int
  weightMethod WeightMethod @default(MANUAL)
  startDate    DateTime?    @db.Date
  endDate      DateTime?    @db.Date
  order        Int          @default(0)

  subGoals SubGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([missionId])
}

model SubGoal {
  id        String  @id @default(uuid())
  midGoalId String
  midGoal   MidGoal @relation(fields: [midGoalId], references: [id], onDelete: Cascade)

  name         String
  weight       Int
  weightMethod WeightMethod @default(MANUAL)
  startDate    DateTime?    @db.Date
  endDate      DateTime?    @db.Date
  order        Int          @default(0)

  tasks GoalTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([midGoalId])
}

model GoalTask {
  id        String  @id @default(uuid())
  subGoalId String
  subGoal   SubGoal @relation(fields: [subGoalId], references: [id], onDelete: Cascade)

  name      String
  weight    Int
  progress  Int       @default(0)
  phase     Phase     @default(PREPARATION)
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  order     Int       @default(0)

  scheduleProgress ScheduleProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subGoalId])
}

enum MissionTypeEnum {
  PRIMARY
  SUB
}

enum WeightMethod {
  EQUAL
  PERIOD
  MANUAL
}

enum Phase {
  PREPARATION
  EXECUTION
  COMPLETED
  REVIEW
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

// ========================================
// プロジェクト管理
// ========================================

model Project {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectName String
  description String?   @db.Text
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  phase       Phase     @default(PREPARATION)
  themeColor  String?   // プロジェクトのテーマカラー（HEX形式）

  missionId String?
  mission   Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)

  approvalStatus  ApprovalStatus @default(DRAFT)
  approvalComment String?        @db.Text
  approvedBy      String?
  approvedAt      DateTime?

  tags String[]

  /// プロジェクト達成フラグ（ミッション進捗計算に使用）
  isAchieved Boolean @default(false)
  achievedAt DateTime?

  /// 関わった町民のContact ID配列
  relatedContactIds String[] @default([])

  members          ProjectMember[]
  tasks            ProjectTask[]
  relatedTasks     Task[] // このプロジェクトに関連するタスク（小目標、任意）
  schedules        Schedule[]
  events           Event[]
  contactHistories ContactHistory[]
  requests         Request[] // Phase 4: 依頼（旧：タスク依頼）
  inspections      Inspection[] // Phase 4
  activityExpenseEntries ActivityExpenseEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([missionId])
}

model ProjectMember {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole @default(SUPPORT)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectTask {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskName   String
  progress   Int       @default(0)
  assignedTo String?
  assignee   User?     @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  deadline   DateTime? @db.Date
  order      Int       @default(0)

  scheduleProgress ScheduleProgress[]
  request          Request? // Phase 4: 依頼との紐付け（旧：タスク依頼）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assignedTo])
}

// ========================================
// タスク（ミッション配下、プロジェクトは任意）
// ========================================

model Task {
  id        String  @id @default(uuid())
  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  title       String
  description String?    @db.Text
  status      TaskStatus @default(NOT_STARTED)
  order       Int        @default(0)
  dueDate     DateTime?  @db.Date // タスクの期日（スケジュール自動生成用）
  /// プロジェクト未紐づけ時は UNSET / KYORYOKUTAI_WORK、プロジェクトありは PROJECT
  linkKind    MissionTaskLinkKind @default(PROJECT)

  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([missionId])
  @@index([projectId])
  @@index([missionId, status])
  @@index([projectId, status])
}

enum TaskStatus {
  NOT_STARTED // 未着手
  IN_PROGRESS // 進行中
  COMPLETED // 完了
}

enum MemberRole {
  LEAD
  SUPPORT
  NOT_SET // 未設定
  KYORYOKUTAI_WORK // 協力隊業務
}

enum MissionTaskLinkKind {
  PROJECT
  UNSET // 未設定（プロジェクトに紐づけない）
  KYORYOKUTAI_WORK // 協力隊業務（プロジェクトに紐づけない）
  TRIAGE_PENDING // あとで振り分け（当日メモ・プロジェクト/タスク未割当）
}

// ========================================
// 相談（メンバー → サポート/行政）
// ========================================

model Consultation {
  id       String @id @default(uuid())
  memberId String
  member   User   @relation("ConsultationMember", fields: [memberId], references: [id], onDelete: Cascade)

  audience ConsultationAudience
  /// audience が SPECIFIC_USER のときのみ
  targetUserId String?
  targetUser   User?   @relation("ConsultationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  subject String? @db.VarChar(400)
  body    String  @db.Text

  status ConsultationStatus @default(OPEN)

  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?   @relation("ConsultationResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedUsers User[] @relation("ConsultationAssignedUsers")
  comments      ConsultationComment[]

  @@index([memberId, status])
  @@index([status, createdAt])
  @@index([audience, status])
}

model ConsultationComment {
  id             String   @id @default(uuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User     @relation("ConsultationCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body           String   @db.Text
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([consultationId])
  @@index([authorId])
}

enum ConsultationAudience {
  ANY // 誰でも（サポート・行政・マスターが受け取れる）
  SUPPORT_ONLY
  GOVERNMENT_ONLY
  SPECIFIC_USER
}

enum ConsultationStatus {
  OPEN
  RESOLVED
}

// ========================================
// 活動経費（隊員ごと）
// ========================================

model ActivityExpenseBudget {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation("ActivityExpenseBudgetMember", fields: [userId], references: [id], onDelete: Cascade)
  allocatedAmount Int      @default(0) // 円（使える上限の目安）
  memo            String?  @db.Text
  updatedById     String?
  updatedBy       User?    @relation("ActivityExpenseBudgetStaffUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 活動経費の購入手順（行政・サポート・マスターが編集）
model ActivityExpenseGuidance {
  id            String   @id @default("default")
  procedureText String   @default("") @db.Text
  updatedAt     DateTime @updatedAt
}

// 経費として使えるかの公式チェックリスト（〇=可 / ✕=不可）
model ActivityExpenseChecklistItem {
  id        String   @id @default(uuid())
  label     String   @db.VarChar(500)
  allowed   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

// 過去の承認済み具体例（ミッション必須・理由付き）
model ActivityExpenseApprovedExample {
  id          String   @id @default(uuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  summary     String   @db.VarChar(500)
  rationale   String   @db.Text
  createdById String
  createdBy   User     @relation("ActivityExpenseExampleCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([missionId])
}

model ActivityExpenseEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("ActivityExpenseEntryMember", fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  spentAt     DateTime @db.Date
  description String   @db.VarChar(500)
  amount      Int // 円（支出）
  createdById String?
  createdBy   User?    @relation("ActivityExpenseEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?    @relation("ActivityExpenseEntryUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, spentAt])
  @@index([projectId])
}

// ========================================
// お知らせ（スタッフ → メンバー、既読管理）
// ========================================

model AnnouncementCategory {
  id            String         @id @default(uuid())
  name          String
  sortOrder     Int            @default(0)
  colorHex      String?
  announcements Announcement[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Announcement {
  id          String                 @id @default(uuid())
  categoryId  String
  category    AnnouncementCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  title       String                 @db.VarChar(400)
  body        String                 @db.Text
  authorId    String
  author      User                   @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  /// 確認を求める対象: ALL=全員, MEMBER=隊員のみ
  confirmTarget AnnouncementConfirmTarget @default(ALL)
  publishedAt DateTime               @default(now())
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  reads       AnnouncementRead[]

  @@index([categoryId, publishedAt])
  @@index([publishedAt])
}

enum AnnouncementConfirmTarget {
  ALL    // 全員（行政・サポート・マスター・メンバー）
  MEMBER // 隊員（メンバー）のみ
}

model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}

model ScheduleProgress {
  id         String   @id @default(uuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  goalTaskId String?
  goalTask   GoalTask? @relation(fields: [goalTaskId], references: [id], onDelete: Cascade)

  projectTaskId String?
  projectTask   ProjectTask? @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)

  progressBefore Int
  progressAfter  Int

  createdAt DateTime @default(now())

  @@index([scheduleId])
  @@index([goalTaskId])
  @@index([projectTaskId])
}

// ========================================
// スケジュール参加者（共同作業）
// ========================================

model ScheduleParticipant {
  id          String            @id @default(uuid())
  scheduleId  String
  userId      String
  status      ParticipantStatus @default(PENDING)
  respondedAt DateTime?
  schedule    Schedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduleId, userId])
  @@index([scheduleId])
  @@index([userId, status])
}

enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
}

// ========================================
// イベント管理
// ========================================

model Event {
  id        String    @id @default(uuid())
  eventName String
  eventType EventType @default(OTHER)
  date      DateTime  @db.Date // 後方互換性のため残す（startDateと同じ値）
  startDate DateTime  @db.Date // 開始日
  endDate   DateTime  @db.Date // 終了日（デフォルトはstartDateと同じ）
  startTime String?
  endTime   String?

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationText String?
  description  String?   @db.Text

  /// 応援で確保したい人数（目安・個人主催イベント用）
  supportSlotsNeeded Int?

  participationPoint Float @default(1.0)
  preparationPoint   Float @default(0.5)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  surveyEnabled   Boolean @default(false)
  surveyQuestions Json?

  createdBy String
  creator   User   @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  updatedBy String?
  updater   User?   @relation("EventUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  participations EventParticipation[]
  schedules      Schedule[] @relation("ScheduleSupportEvent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType, date])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([locationId])
  @@index([projectId])
}

/// 役場・スタッフが設定する「隊員全員の参加が必要な業務イベント」（個人主催の Event とは別）
model MandatedTeamEvent {
  id            String   @id @default(uuid())
  title         String   @db.VarChar(400)
  description   String?  @db.Text
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  requiredSlots Int // 必要人数（目安・要件）
  createdById   String
  creator       User     @relation("MandatedTeamEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  attendances   MandatedTeamEventAttendance[]
  auditLogs     MandatedAttendanceAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
}

/// 隊員参加枠チェックの変更履歴（誰が・いつ）
model MandatedAttendanceAuditLog {
  id          String   @id @default(uuid())
  eventId     String
  userId      String
  attended    Boolean
  changedById String
  createdAt   DateTime @default(now())

  event     MandatedTeamEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member    User              @relation("MandatedAttendanceMember", fields: [userId], references: [id], onDelete: Cascade)
  changedBy User              @relation("MandatedAttendanceChangedBy", fields: [changedById], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([userId])
}

model MandatedTeamEventAttendance {
  id        String          @id @default(uuid())
  eventId   String
  event     MandatedTeamEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attended  Boolean         @default(false)
  updatedAt DateTime        @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
}

model EventParticipation {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  participationType ParticipationType @default(PARTICIPATION)
  pointEarned       Float             @default(0)
  surveyResponse    Json?
  status            ParticipantStatus @default(PENDING)
  respondedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId, status])
}

enum EventType {
  TOWN_OFFICIAL
  TEAM
  OTHER
}

enum ParticipationType {
  PARTICIPATION
  PREPARATION
  DEPARTMENT_DUTY
}

// ========================================
// SNS投稿管理
// ========================================

model SNSPost {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SNSアカウント（任意・未設定時はデフォルトアカウント扱い）
  accountId String?
  account   SNSAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  // 週のキー（YYYY-WW形式、月曜9:00 JST基準で週を判定）
  week String

  // 投稿日時（必須。週次判定と履歴表示に使用）
  postedAt DateTime @db.Timestamptz

  // 投稿種別（STORY/FEED、BOTHは廃止予定）
  postType PostType

  // 以下は任意入力（分析/ブランディング用）
  url            String? // 投稿リンク
  theme          String? @db.VarChar(200) // 投稿テーマ（タイトル）
  followerCount  Int? // その時点のフォロワー数（任意・週次・月次集計用）
  followerDelta  Int? // フォロワー増減数（レガシー）
  views         Int? // 閲覧数（Instagramのリーチ等）
  likes         Int? // いいね数
  note          String? @db.Text // 備考

  // 後方互換性のため残す（削除予定）
  postDate DateTime? @db.Date
  isPosted Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, week, postType, accountId], name: "userId_week_postType_accountId")
  @@index([userId, week])
  @@index([userId, postedAt])
  @@index([accountId])
}

// SNSアカウント（ユーザーが複数持てる）
model SNSAccount {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform    String  @db.VarChar(50)  // 'instagram', 'twitter', 'tiktok' 等
  accountName String  @db.VarChar(200) // @username 等
  displayName String? @db.VarChar(200) // 表示名
  url         String? @db.Text         // プロフィールURL
  isDefault   Boolean @default(false)  // デフォルトアカウント

  posts SNSPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum PostType {
  STORY
  FEED
  BOTH
}

// ========================================
// 月次報告
// ========================================

model MonthlyReport {
  id        String @id @default(uuid())
  month     String
  createdBy String
  creator   User   @relation("MonthlyReportCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  coverRecipient String @default("長沼町長 斎藤良彦様")
  coverSender    String @default("一般社団法人まおいのはこ 代表理事 坂本一志")

  memberSheets Json

  submittedAt DateTime?

  supportRecords SupportRecord[]
  revisions      MonthlyReportRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month])
}

model MonthlyReportRevision {
  id              String        @id @default(uuid())
  monthlyReportId String
  monthlyReport   MonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)

  changedBy String
  changer   User   @relation("MonthlyReportRevisionChanger", fields: [changedBy], references: [id], onDelete: Cascade)

  changes Json // 変更内容をJSON形式で保存
  reason  String? @db.Text // 変更理由

  createdAt DateTime @default(now())

  @@index([monthlyReportId])
}

model SupportRecord {
  id              String         @id @default(uuid())
  monthlyReportId String?
  monthlyReport   MonthlyReport? @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  supportDate    DateTime @db.Date
  supportContent String   @db.Text
  supportBy      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([monthlyReportId])
  @@index([userId])
}

// ========================================
// 町民データベース
// ========================================

model Contact {
  id           String   @id @default(uuid())
  name         String
  organization String?
  title        String?
  contactInfo  String?
  memo         String?  @db.Text
  tags         String[]

  // 協力隊メンバー情報（新規追加）
  role      String? // '現役' | 'OB' | 'サポート' | '役場'
  startYear Int? // 任期開始年
  endYear   Int? // 任期終了年

  // 新規追加フィールド
  category         String? // ジャンル
  relatedMembers   String[] // 関わった協力隊（User IDの配列）
  relationshipType String? // 関わり方: '協力的' | '要注意' | '未知' | '未登録'
  instagramUrl     String? // InstagramのURL

  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  histories ContactHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
  @@index([category])
  @@index([relationshipType])
}

model ContactHistory {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date    DateTime @db.Date
  content String   @db.Text

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([userId])
  @@index([projectId])
}

// ========================================
// スケジュール提案（Phase 3）
// ========================================

model ScheduleSuggestion {
  id          String   @id @default(uuid())
  scheduleId  String
  schedule    Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  suggestedTo String
  user        User     @relation(fields: [suggestedTo], references: [id], onDelete: Cascade)

  status               SuggestionStatus @default(PENDING)
  conflictingSchedules Json? // 衝突する予定のID配列

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@unique([scheduleId, suggestedTo])
  @@index([suggestedTo, status])
  @@index([scheduleId])
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  DECLINED
  IGNORED
}

// ========================================
// システム設定
// ========================================

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// ========================================
// テンプレート設定
// ========================================

model DocumentTemplate {
  id           String @id @default(uuid())
  templateType String @unique // 'weekly_report' | 'monthly_report' | 'inspection'

  // 週次報告テンプレート設定
  weeklyReportRecipient String? // 宛先
  weeklyReportTitle     String? // タイトル

  // 月次報告テンプレート設定
  monthlyReportRecipient String? // 宛先
  monthlyReportSender    String? // 差出人
  monthlyReportTitle     String? // タイトル
  monthlyReportText1     String? // テキスト1
  monthlyReportText2     String? // テキスト2
  monthlyReportContact   String? // 担当者情報

  // 復命書テンプレート設定
  inspectionRecipient  String? // 宛先
  inspectionTitle      String? // タイトル
  inspectionNamePrefix String? // 氏名のプレフィックス（例：〇〇課　地域おこし協力隊）
  inspectionText1      String? // テキスト1
  inspectionItem1      String? // 項目1（日時）の参考テキスト
  inspectionItem2      String? // 項目2（場所）の参考テキスト
  inspectionItem3      String? // 項目3（用務）の参考テキスト
  inspectionItem4      String? // 項目4（目的）の参考テキスト
  inspectionItem5      String? // 項目5（内容）の参考テキスト
  inspectionItem6      String? // 項目6（処理てん末）の参考テキスト
  inspectionItem7      String? // 項目7（所感・今後）の参考テキスト
  inspectionItem8      String? // 項目8（その他報告）の参考テキスト

  updatedBy String?
  updater   User?   @relation("TemplateUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================================
// 依頼（Phase 4、旧：タスク依頼）
// ========================================

model Request {
  id          String @id @default(uuid())
  requestedBy String
  requester   User   @relation("Requester", fields: [requestedBy], references: [id], onDelete: Cascade)
  requestedTo String
  requestee   User   @relation("Requestee", fields: [requestedTo], references: [id], onDelete: Cascade)

  requestTitle       String
  requestDescription String    @db.Text
  deadline           DateTime? @db.Date

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  approvalStatus ApprovalStatus @default(PENDING)
  approvalNote   String?        @db.Text
  approvedAt     DateTime?

  createdTaskId String?      @unique
  createdTask   ProjectTask? @relation(fields: [createdTaskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestedBy])
  @@index([requestedTo])
  @@index([approvalStatus])
}

// ========================================
// 視察復命書（Phase 4）
// ========================================

model Inspection {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date         DateTime @db.Date
  destination  String
  purpose      String   @db.Text
  participants String[]

  inspectionPurpose String @db.Text
  inspectionContent String @db.Text
  reflection        String @db.Text
  futureAction      String @db.Text

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

// ========================================
// 個人事業モード（Phase 4）
// ========================================

model PersonalProject {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectName String
  description String?   @db.Text
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  phase       Phase     @default(PREPARATION)

  tasks     PersonalTask[]
  schedules PersonalSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PersonalTask {
  id        String          @id @default(uuid())
  projectId String
  project   PersonalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskName String
  progress Int       @default(0)
  deadline DateTime? @db.Date
  order    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model PersonalSchedule {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  startTime String
  endTime   String

  projectId String?
  project   PersonalProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  activityDescription String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

// ========================================
// 通知システム（Phase 4）
// ========================================

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String           @db.Text
  link    String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  SCHEDULE_SUGGESTION
  TASK_REQUEST
  PROJECT_APPROVED
  PROJECT_REJECTED
  WEEKLY_REMINDER
  SNS_REMINDER
  PENDING_SCHEDULE
  EVENT_REMINDER
  SCHEDULE_INVITE
  SCHEDULE_INVITE_APPROVED
  SCHEDULE_INVITE_REJECTED
}

// ========================================
// 協力隊催促（Nudge）
// ========================================

model NudgeDocument {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  publishedAt DateTime
  updatedAt   DateTime @updatedAt
  updatedBy   String
  updater     User     @relation("NudgeUpdater", fields: [updatedBy], references: [id], onDelete: Cascade)

  revisions NudgeRevision[]

  createdAt DateTime @default(now())
}

model NudgeRevision {
  id         String        @id @default(uuid())
  documentId String
  document   NudgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String        @db.Text
  updatedBy  String
  updater    User          @relation("NudgeRevisionUpdater", fields: [updatedBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([createdAt])
}

// ========================================
// やりたいこと100（Bucket List 100）
// ========================================

enum WishStatus {
  ACTIVE
  DONE
  PAUSED
}

enum WishDifficulty {
  EASY
  MEDIUM
  HARD
}

enum WishEstimate {
  S
  M
  L
}

enum WishPriority {
  LOW
  MID
  HIGH
}

enum WishCheckinType {
  REFLECTION
  NOTE
}

model Wish {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String // 必須、短い
  category    String? // 任意：文字列（自由入力）
  status      WishStatus      @default(ACTIVE)
  difficulty  WishDifficulty?
  estimate    WishEstimate?
  priority    WishPriority?
  dueMonth    Int? // 1..12（日付ではなく月まで）
  tags        String[] // 文字列配列
  memo        String?         @db.Text
  completedAt DateTime?

  checkins WishCheckin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([dueMonth])
  @@index([createdAt])
}

model WishCheckin {
  id     String @id @default(uuid())
  wishId String
  wish   Wish   @relation(fields: [wishId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    WishCheckinType
  content String          @db.Text

  createdAt DateTime @default(now())

  @@index([wishId])
  @@index([userId])
  @@index([createdAt])
}

// Googleドライブリンク管理
model DriveLink {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200) // 項目名（例：「プロジェクト資料」「画像フォルダ」）
  url         String   @db.Text // GoogleドライブのURL
  description String?   @db.Text // 説明（任意）
  order       Int      @default(0) // 表示順
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// ========================================
// 行政出勤記録（役場スタッフの出勤状況）
// ========================================

model GovernmentAttendance {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  endDate   DateTime? @db.Date  // 出張など複数日の場合の終了日
  startTime String?  @db.VarChar(5)  // HH:mm 形式（連絡可能開始時間）
  endTime   String?  @db.VarChar(5)  // HH:mm 形式（連絡可能終了時間）
  status GovernmentAttendanceStatus @default(PRESENT)
  note   String?  @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}

enum GovernmentAttendanceStatus {
  PRESENT    // 出勤
  REMOTE     // 出張
  ABSENT     // 不在
  HALF_DAY   // 半日
}

// ========================================
// メモ帳
// ========================================

model Notepad {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String   @db.VarChar(200)
  content   String   @db.Text
  order     Int      @default(0) // 表示順

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, order])
}

// ========================================
// 有給・代休管理
// ========================================

/// 有給付与設定（管理側が隊員ごとに設定）
model PaidLeaveAllocation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("PaidLeaveAllocationMember", fields: [userId], references: [id], onDelete: Cascade)
  fiscalYear  Int      // 年度（例: 2025 = 2025年4月〜2026年3月）
  totalDays   Float    // 付与日数
  expiresAt   DateTime @db.Date // 有効期限（その年度の3月31日）
  memo        String?  @db.Text
  updatedById String?
  updatedBy   User?    @relation("PaidLeaveAllocationUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, fiscalYear])
  @@index([userId])
}

/// 有給使用記録
model PaidLeaveEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("PaidLeaveEntryMember", fields: [userId], references: [id], onDelete: Cascade)
  usedAt      DateTime @db.Date
  days        Float    // 使用日数（0.5日単位）
  note        String?  @db.VarChar(500)
  createdById String?
  createdBy   User?    @relation("PaidLeaveEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, usedAt])
}

/// 無休使用記録（メンバーも追加可）
model UnpaidLeaveEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UnpaidLeaveEntryMember", fields: [userId], references: [id], onDelete: Cascade)
  usedAt      DateTime @db.Date
  days        Float    // 使用日数
  note        String?  @db.VarChar(500)
  createdById String?
  createdBy   User?    @relation("UnpaidLeaveEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, usedAt])
}

/// 代休（休日出勤タスクから発生）
model CompensatoryLeave {
  id          String                @id @default(uuid())
  userId      String
  user        User                  @relation("CompensatoryLeaveMember", fields: [userId], references: [id], onDelete: Cascade)
  grantedAt   DateTime              @db.Date // 代休が付与された日（休日出勤した日）
  expiresAt   DateTime              @db.Date // 期限（grantedAt + 56日）
  scheduleId  String?               // 紐づくスケジュール
  schedule    Schedule?             @relation("CompensatoryLeaveSchedule", fields: [scheduleId], references: [id], onDelete: SetNull)
  totalHours  Float?                // 発生した時間（タスクから自動入力、変更可）
  leaveType   CompensatoryLeaveType @default(FULL_DAY) // 代休 or 時間調整
  status      CompensatoryLeaveStatus @default(PENDING)
  note        String?               @db.VarChar(500)
  confirmedById String?
  confirmedBy   User?               @relation("CompensatoryLeaveConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  confirmedAt   DateTime?

  usages         CompensatoryLeaveUsage[]
  timeAdjustments TimeAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, expiresAt])
  @@index([scheduleId])
}

enum CompensatoryLeaveType {
  FULL_DAY      // 代休（1日単位）
  TIME_ADJUST   // 時間調整
}

enum DayOffType {
  PAID          // 有給
  UNPAID        // 無休
  COMPENSATORY  // 代休
  TIME_ADJUST   // 時間調整
}

enum CompensatoryLeaveStatus {
  PENDING   // 未使用
  USED      // 使用済み
  EXPIRED   // 期限切れ
}

/// 代休使用記録
model CompensatoryLeaveUsage {
  id                  String            @id @default(uuid())
  compensatoryLeaveId String
  compensatoryLeave   CompensatoryLeave @relation(fields: [compensatoryLeaveId], references: [id], onDelete: Cascade)
  usedAt              DateTime          @db.Date
  days                Float             // 使用日数（1日単位）
  note                String?           @db.VarChar(500)
  createdById         String?
  createdBy           User?             @relation("CompensatoryLeaveUsageCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now())

  @@index([compensatoryLeaveId])
}

/// 時間調整（代休の時間版）
model TimeAdjustment {
  id                  String             @id @default(uuid())
  userId              String
  user                User               @relation("TimeAdjustmentMember", fields: [userId], references: [id], onDelete: Cascade)
  compensatoryLeaveId String?
  compensatoryLeave   CompensatoryLeave? @relation(fields: [compensatoryLeaveId], references: [id], onDelete: SetNull)
  adjustedAt          DateTime           @db.Date // 早上がりした日
  hours               Float              // 調整時間（タスクから自動入力、変更可）
  sourceScheduleId    String?            // 元になったスケジュール（休日出勤）
  sourceSchedule      Schedule?          @relation("TimeAdjustmentSourceSchedule", fields: [sourceScheduleId], references: [id], onDelete: SetNull)
  // 使用記録（何日の何時から何時で使ったか）
  usedAt              DateTime?          @db.Date // 実際に使用した日
  usedStartTime       String?            @db.VarChar(5) // HH:mm
  usedEndTime         String?            @db.VarChar(5) // HH:mm
  usedScheduleId      String?            // 使用時のスケジュールID
  note                String?            @db.VarChar(500)
  confirmedById       String?
  confirmedBy         User?              @relation("TimeAdjustmentConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  confirmedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([userId, adjustedAt])
  @@index([compensatoryLeaveId])
}
