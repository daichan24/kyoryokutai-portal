# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kyoryokutai

# Backend
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3001

# Google Calendar sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google-calendar/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Email notifications
# console: log only, brevo/resend: external delivery
EMAIL_ENABLED=false
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
BREVO_API_KEY=
RESEND_API_KEY=

# Frontend
VITE_API_URL=http://localhost:3001
